# Generated by Cargo
# will have compiled files and executables
/target/

# These are backup files generated by rustfmt
**/*.rs.bk

# Files generated by build processes or applications
config.yml
db
logos_blockchain_db
store.*
sim_config.json
*.txt
.env
.idea/
.vscode/
.cache/
null

# Integration test temp dirs
tests/.run_*

# Wildcard for any file that contains ignore
*ignore*

# C headers
c-bindings/logos_blockchain.h

# Demo sequencer related ignores
node_modules
*.database
/tests/cucumber_tests/temp/
/tests/.e2e_artefacts

# Nix
result

# Docker
tempo-data/

# Python
**.pyc

# Runtime/test logs generated by workspace tests
**/*.log
**/*.log.[0-9]*

# tx-service runtime recovery artifacts (numeric filenames)
services/tx-service/[0-9]*

# testnet cfgsync generated local deployment file
testnet/cfgsync/deployment-settings.yaml

# Claude folder. We don't enforce any team-wide rules yet.
.claude/**